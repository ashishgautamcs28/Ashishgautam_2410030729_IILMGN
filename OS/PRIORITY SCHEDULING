#include<stdio.h>

struct process
{
    int at, bt, pr, ct, tat, wt, completed;
};

int main()
{
    int n,time=0,completed=0;
    struct process p[10];
    
    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++)
    {
        printf("Enter AT BT Priority for P%d: ",i+1);
        scanf("%d%d%d",&p[i].at,&p[i].bt,&p[i].pr);
        p[i].completed=0;
    }

    while(completed<n)
    {
        int idx=-1;
        int highest=999;

        for(int i=0;i<n;i++)
        {
            if(p[i].at<=time && p[i].completed==0)
            {
                if(p[i].pr<highest)
                {
                    highest=p[i].pr;
                    idx=i;
                }
            }
        }

        if(idx!=-1)
        {
            time += p[idx].bt;
            p[idx].ct = time;
            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;
            p[idx].completed = 1;
            completed++;
        }
        else
        time++;
    }

    printf("\nProcess AT BT PR CT TAT WT\n");

    for(int i=0;i<n;i++)
    {
        printf("P%d %d %d %d %d %d %d\n",
        i+1,p[i].at,p[i].bt,p[i].pr,p[i].ct,p[i].tat,p[i].wt);
    }
}
