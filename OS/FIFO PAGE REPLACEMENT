#include <stdio.h>

int main() {
    int frames[10], pages[30];
    int n, f, i, j, k, index = 0;
    int pageFaults = 0, flag;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter the page reference string:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &pages[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &f);

    // Initialize frames
    for(i = 0; i < f; i++) {
        frames[i] = -1;
    }

    // FIFO Logic
    for(i = 0; i < n; i++) {
        flag = 0;

        // Check HIT
        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                flag = 1;
                break;
            }
        }

        // MISS
        if(flag == 0) {
            frames[index] = pages[i];
            index = (index + 1) % f;
            pageFaults++;
        }

        // Print frame status
        printf("\n");
        for(k = 0; k < f; k++) {
            printf("%d\t", frames[k]);
        }
    }

    printf("\n\nTotal Page Faults = %d\n", pageFaults);

    return 0;
}
